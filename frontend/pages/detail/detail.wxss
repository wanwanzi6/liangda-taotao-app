/* pages/detail/detail.wxss - 活力橙黄风 **/
page {
  --primary: #FFB800;
  --primary-dark: #FF9500;
  --accent: #FF6B35;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --bg-page: #FFF8ED;
  --bg-card: #FFFFFF;
  --shadow-sm: 0 4rpx 16rpx rgba(255, 184, 0, 0.12);
  --shadow-md: 0 8rpx 32rpx rgba(255, 184, 0, 0.18);
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 40rpx;
}

.container {
  background-color: var(--bg-page);
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 顶部内容区 - 卡片式设计 */
.header-section {
  background: var(--bg-card);
  margin: 24rpx;
  padding: 36rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

/* 价格行 - 突出显示 */
.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.symbol {
  color: var(--accent);
  font-size: 32rpx;
  font-weight: 800;
}

.price-value {
  color: var(--accent);
  font-size: 64rpx;
  font-weight: 900;
  margin-right: 20rpx;
  letter-spacing: -2rpx;
}

.condition-tag {
  font-size: 24rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  color: #E65100;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

/* 商品标题 */
.product-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 28rpx;
  line-height: 1.5;
}

/* 商品描述 */
.product-desc {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  padding: 28rpx;
  background: #FAFAFA;
  border-radius: var(--radius-sm);
}

/* 图片区 */
.image-section {
  margin: 0 24rpx;
}

.image-placeholder {
  width: 100%;
  height: 600rpx;
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* 底部操作栏 - 悬浮卡片 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bar-left {
  display: flex;
  flex: 1;
  gap: 40rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.bar-right {
  display: flex;
  gap: 16rpx;
}

.chat-btn, .buy-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 700;
  padding: 0 44rpx;
}

.chat-btn {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #333;
  box-shadow: 0 6rpx 20rpx rgba(255, 184, 0, 0.4);
}

.buy-btn {
  background: linear-gradient(135deg, #333 0%, #1a1a1a 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.3);
}
