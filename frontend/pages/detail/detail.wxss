/* pages/detail/detail.wxss */
.container {
  background-color: #ffffff;
  min-height: 100vh;
  padding-bottom: 120rpx; /* 为底部工具栏留位 */
}

/* 顶部内容区 */
.header-section {
  padding: 30rpx 40rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.symbol {
  color: #ff4400;
  font-size: 32rpx;
  font-weight: bold;
}

.price-value {
  color: #ff4400;
  font-size: 56rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.condition-tag {
  font-size: 24rpx;
  background-color: #fffbe6;
  color: #faad14;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.product-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.product-desc {
  font-size: 30rpx;
  color: #444;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

/* 图片区 */
.image-section {
  padding: 0 20rpx;
}

.image-placeholder {
  width: 100%;
  height: 600rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ccc;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-top: 1rpx solid #eee;
}

.bar-left {
  display: flex;
  flex: 1;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  font-size: 20rpx;
  color: #666;
}

.bar-right {
  display: flex;
  gap: 15rpx;
}

.chat-btn, .buy-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  padding: 0 40rpx;
}

.chat-btn {
  background-color: #FFD900;
  color: #333;
}

.buy-btn {
  background-color: #000;
  color: #fff;
}