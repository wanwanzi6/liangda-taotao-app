/** index.wxss **/
.container { 
  background-color: #f7f7f7; 
  min-height: 100vh; 
}

/* 1. 全宽沉浸式顶部：黄色背景占满宽度并置顶 */
.nav-header {
  background-color: #FFD900;
  width: 100%;             
  box-sizing: border-box;  
  padding: 80rpx 30rpx 50rpx 30rpx; 
  position: sticky;
  top: 0;
  z-index: 100;
}

/* 2. 搜索框：白色圆角矩形 */
.search-box {
  background: #ffffff;
  border-radius: 40rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-box icon {
  margin-right: 15rpx;
}

.search-box text {
  font-size: 26rpx;
  color: #999;
}

/* 3. 分类导航：白色圆角卡片向上错层 */
.category-nav {
  white-space: nowrap;
  background: #ffffff;
  padding: 24rpx 0;
  border-top-left-radius: 36rpx;  
  border-top-right-radius: 36rpx;
  margin-top: -30rpx;             
  position: relative;
  z-index: 101;
  border-bottom: 1rpx solid #f2f2f2;
}

.nav-item {
  display: inline-block;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  height: 60rpx;
  line-height: 60rpx;
}

/* 4. 选中状态小横条 */
.nav-item.active {
  color: #000;
  font-weight: bold;
  font-size: 30rpx;
}

.nav-item.active:after {
  content: '';
  position: absolute;
  bottom: 0rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 8rpx;
  background: #FFD900;
  border-radius: 4rpx;
}

/* 5. 商品卡片与图片处理 */
.product-list { 
  padding: 20rpx; 
  display: flex; 
  flex-wrap: wrap; 
  justify-content: space-between; 
}

.product-card { 
  width: 345rpx; 
  background: #fff; 
  border-radius: 20rpx; 
  margin-bottom: 20rpx; 
  overflow: hidden; 
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); 
}

/* 图片容器：固定高度，裁剪多余部分 */
.product-image-wrap {
  width: 100%;
  height: 345rpx; /* 1:1 比例 */
  background: #f5f5f5;
  position: relative;
  overflow: hidden;
}

/* 真实图片样式 */
.product-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 兜底占位样式 */
.product-image-placeholder { 
  width: 100%; 
  height: 100%; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  color: #ccc; 
  font-size: 24rpx; 
}

/* 6. 商品文字信息 */
.product-info { padding: 20rpx; }

.product-title { 
  font-size: 28rpx; 
  color: #333; 
  height: 80rpx; 
  display: -webkit-box; 
  -webkit-box-orient: vertical; 
  -webkit-line-clamp: 2; 
  overflow: hidden; 
  line-height: 40rpx;
}

.product-price-row { 
  margin-top: 12rpx; 
  display: flex; 
  align-items: baseline; 
}

.price-symbol { color: #ff4400; font-size: 24rpx; font-weight: bold; }
.price-value { color: #ff4400; font-size: 38rpx; font-weight: bold; margin-left: 2rpx; }

.status-tag { 
  font-size: 20rpx; 
  background: #fff1f0; 
  color: #ff4d4f; 
  padding: 2rpx 10rpx; 
  border-radius: 6rpx; 
  margin-left: 10rpx; 
}

.loading-tips { text-align: center; font-size: 24rpx; color: #999; padding: 40rpx; width: 100%; }