/** index.wxss - 极致紧凑+切换不抖动 **/
page {
  --primary: #FFB800;
  --primary-dark: #FF9500;
  --primary-light: #FFD666;
  --accent: #FF6B35;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --bg-page: #FFF8ED;
  --bg-card: #FFFFFF;
  --shadow-sm: 0 4rpx 12rpx rgba(255, 184, 0, 0.1);
  --shadow-md: 0 8rpx 24rpx rgba(255, 184, 0, 0.15);
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
}

.container {
  background-color: var(--bg-page);
  min-height: 100vh;
  /* 必须确保允许向上溢出，否则切换瞬间负位移会失效 */
  overflow: visible !important; 
  padding-top: 0;
}

/* 1. 顶部搜索区 - 保持不动 */
.nav-header {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  width: 100%;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 90rpx) 30rpx 30rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-header::before {
  content: '量大淘淘';
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  padding-top: 10rpx;
  margin-bottom: 24rpx; 
  letter-spacing: 4rpx;
}

.search-box {
  background: #ffffff;
  border-radius: var(--radius-lg);
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  box-shadow: var(--shadow-md);
}

/* 2. 分类导航 - 锁定位置 */
.category-nav {
  white-space: nowrap;
  background: var(--bg-card);
  padding: 0;
  width: 100%;
  position: relative;
  /* 沿用你调好的参数 */
  top: -60rpx; 
  z-index: 101;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
  border-radius: 40rpx 40rpx 0 0;
}

.nav-item {
  display: inline-block;
  padding: 0 32rpx;
  height: 90rpx; 
  line-height: 90rpx;
  font-size: 28rpx;
}

.nav-item.active {
  color: var(--primary-dark);
  font-weight: 700;
  position: relative;
}

.nav-item.active::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--primary-dark);
  border-radius: 3rpx;
}

/* 3. 瀑布流容器 - 核心：强制执行你的调优参数 */
.waterfall-container {
  display: flex !important;
  box-sizing: border-box;
  /* 强制保持贴边 */
  padding: 0 6rpx !important; 
  
  position: relative;
  /* 沿用你调好的参数 */
  top: -110rpx; 
  
  justify-content: space-between;
  align-items: flex-start;
  width: 100%;
  
  /* 关键：增加最小高度，防止切换瞬间容器高度归零导致位移锚点丢失 */
  min-height: 800rpx; 
}

.column-left, .column-right {
  /* 强制锁定宽度，不受内容影响 */
  width: 49.5% !important; 
  display: flex;
  flex-direction: column;
}

.product-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 12rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.product-img {
  width: 100%;
  display: block;
}

.product-info {
  padding: 16rpx;
}

.price-value {
  color: var(--accent);
  font-size: 40rpx;
  font-weight: 800;
}

/* 加载提示也要跟着位移 */
.loading-tips {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  padding: 30rpx;
  position: relative;
  top: -410rpx;
}