<!--pages/post/post.wxml-->
<view class="container">
  <!-- 融合式大卡片：图片 + 描述 -->
  <view class="main-card">
    <view class="main-content">
      <!-- 左侧图片区域 -->
      <view class="image-section" bindtap="chooseImage">
        <image wx:if="{{tempImageUrl}}" src="{{tempImageUrl}}" mode="aspectFill" class="preview-image"></image>
        <view wx:else class="upload-placeholder">
          <text class="plus-icon">📷</text>
        </view>
        <view class="uploading-mask" wx:if="{{isUploading}}">
          <text>上传中...</text>
        </view>
      </view>

      <!-- 右侧描述区域 -->
      <view class="desc-section">
        <textarea
          class="input-desc"
          placeholder="描述一下宝贝的品牌型号、货源来源、新旧程度...建议第一行写下宝贝名称。"
          placeholder-class="ph-color"
          bindinput="onInputDesc"
        ></textarea>
      </view>
    </view>
  </view>

  <!-- 价格和分类 -->
  <view class="cell-group">
    <view class="cell">
      <text>价格</text>
      <input type="digit" placeholder="0.00" placeholder-class="ph-color" bindinput="onInputPrice" />
    </view>

    <picker bindchange="onCategoryChange" range="{{categories}}" range-key="Name">
      <view class="cell">
        <text>分类</text>
        <text class="{{selectedCategory ? '' : 'placeholder'}}">
          {{selectedCategory ? selectedCategory.Name : '选择分类'}}
        </text>
      </view>
    </picker>
  </view>

  <!-- 发布按钮 -->
  <button class="submit-btn" bindtap="submitPost" disabled="{{isUploading}}">
    {{isUploading ? '图片上传中...' : '立即发布'}}
  </button>
</view>
