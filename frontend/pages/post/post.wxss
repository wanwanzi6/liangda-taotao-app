/* pages/post/post.wxss - 活力橙黄风 **/
page {
  --primary: #FFB800;
  --primary-dark: #FF9500;
  --accent: #FF6B35;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --bg-page: #FFF8ED;
  --bg-card: #FFFFFF;
  --bg-input: #FAFAFA;
  --shadow-sm: 0 4rpx 16rpx rgba(255, 184, 0, 0.12);
  --shadow-md: 0 8rpx 32rpx rgba(255, 184, 0, 0.18);
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 40rpx;
}

.container {
  padding: 24rpx;
  background: var(--bg-page);
  min-height: 100vh;
}

/* 1. 图片上传区域 - 渐变边框 */
.image-uploader {
  width: 100%;
  height: 420rpx;
  background: var(--bg-card);
  margin-bottom: 24rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  box-shadow: var(--shadow-sm);
  border: 3rpx dashed var(--primary-light);
}

.image-uploader:not(:empty) {
  border: none;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: var(--text-tertiary);
}

.plus-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  font-weight: 300;
  color: #fff;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 0, 0.3);
}

.upload-placeholder text {
  font-size: 28rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.uploading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

/* 2. 表单组 - 卡片式 */
.form-group {
  background: var(--bg-card);
  padding: 32rpx;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.input-title {
  font-size: 34rpx;
  font-weight: 600;
  border-bottom: 2rpx solid var(--bg-input);
  padding: 24rpx 0;
  color: var(--text-primary);
}

.input-desc {
  font-size: 30rpx;
  padding: 24rpx 0;
  width: 100%;
  height: 240rpx;
  color: var(--text-primary);
}

/* 3. 单元格组 */
.cell-group {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

.cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--bg-input);
  font-size: 30rpx;
  color: var(--text-primary);
}

.cell:last-child {
  border-bottom: none;
}

.placeholder {
  color: var(--text-tertiary);
}

/* 4. 发布按钮 - 渐变主按钮 */
.submit-btn {
  margin-top: 48rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
  border-radius: var(--radius-lg) !important;
  font-weight: 700 !important;
  font-size: 34rpx !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  color: #333 !important;
  box-shadow: 0 12rpx 40rpx rgba(255, 184, 0, 0.4) !important;
  border: none !important;
}

/* 按钮点击态 */
.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 禁用态样式 */
.submit-btn[disabled] {
  background: #E0E0E0 !important;
  color: #999 !important;
  box-shadow: none !important;
}

/* 输入框占位符样式 */
input::placeholder,
textarea::placeholder {
  color: var(--text-tertiary);
}
