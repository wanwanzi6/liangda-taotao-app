/* pages/post/post.wxss - 极简发布布局 **/
page {
  --primary: #FFB800;
  --primary-dark: #FF9500;
  --primary-light: #FFD666;
  --accent: #FF6B35;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --bg-page: #F5F5F5;
  --bg-card: #FFFFFF;
  --bg-input: #F8F8F8;
  --shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --radius-sm: 16rpx;
  --radius-md: 20rpx;
  --radius-lg: 40rpx;
}

.container {
  padding: 24rpx;
  background: var(--bg-page);
  min-height: 100vh;
  box-sizing: border-box;
  padding-top: 0;
}

/* ========== 融合式大卡片 ========== */
.main-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  margin-bottom: 24rpx;
}

.main-content {
  display: flex;
  padding: 24rpx;
  min-height: 300rpx;
}

/* 左侧图片区域 */
.image-section {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--bg-input);
  position: relative;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-input);
}

.plus-icon {
  font-size: 48rpx;
  opacity: 0.5;
}

.uploading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 右侧描述区域 */
.desc-section {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  align-items: flex-start;
}

.input-desc {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  padding: 0;
  background: transparent;
}

/* 占位符颜色 */
.ph-color {
  color: var(--text-tertiary);
}

/* ========== 价格和分类卡片 ========== */
.cell-group {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  margin-bottom: 32rpx;
}

.cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--bg-input);
  font-size: 30rpx;
  color: var(--text-primary);
}

.cell:last-child {
  border-bottom: none;
}

.cell input {
  text-align: right;
  font-size: 30rpx;
  color: var(--text-primary);
  background: transparent;
}

.placeholder {
  color: var(--text-tertiary);
}

/* ========== 发布按钮 ========== */
.submit-btn {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%) !important;
  border-radius: var(--radius-lg) !important;
  font-weight: 700 !important;
  font-size: 34rpx !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  color: #333 !important;
  box-shadow: 0 12rpx 40rpx rgba(255, 184, 0, 0.4) !important;
  border: none !important;
}

.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.submit-btn[disabled] {
  background: #E0E0E0 !important;
  color: #999 !important;
  box-shadow: none !important;
}