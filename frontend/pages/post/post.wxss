/* pages/post/post.wxss */
.container { 
  padding: 30rpx; 
  background: #f7f7f7; 
  min-height: 100vh; 
}

/* 1. 新增：图片上传区域样式 */
.image-uploader {
  width: 100%;
  height: 400rpx;
  background: #fff;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
}

.plus-icon {
  font-size: 100rpx;
  line-height: 1;
  margin-bottom: 10rpx;
  color: #ccc;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.uploading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 2. 表单组样式 */
.form-group { 
  background: #fff; 
  padding: 24rpx 30rpx; 
  border-radius: 20rpx; 
  margin-bottom: 20rpx; 
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.input-title { 
  font-size: 34rpx; 
  font-weight: bold; 
  border-bottom: 1rpx solid #f5f5f5; 
  padding: 20rpx 0; 
}

.input-desc { 
  font-size: 30rpx; 
  padding: 24rpx 0; 
  width: 100%; 
  height: 240rpx; 
}

/* 3. 单元格组样式 */
.cell-group { 
  background: #fff; 
  border-radius: 20rpx; 
  overflow: hidden; 
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.cell { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  padding: 30rpx; 
  border-bottom: 1rpx solid #f5f5f5; 
  font-size: 30rpx; 
}

.cell:last-child {
  border-bottom: none;
}

.placeholder { 
  color: #ccc; 
}

/* 4. 发布按钮样式 */
.submit-btn { 
  margin-top: 60rpx; 
  background: #FFD900 !important; /* 强制使用闲鱼黄 */
  border-radius: 50rpx; 
  font-weight: bold; 
  font-size: 32rpx;
  height: 90rpx;
  line-height: 90rpx;
  color: #000;
}

/* 按钮点击态 */
.submit-btn:active {
  opacity: 0.8;
}

/* 禁用态样式 */
.submit-btn[disabled] {
  background: #eee !important;
  color: #999 !important;
}