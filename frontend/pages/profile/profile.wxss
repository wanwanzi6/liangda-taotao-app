/* pages/profile/profile.wxss - 活力橙黄风 **/
page {
  --primary: #FFB800;
  --primary-dark: #FF9500;
  --primary-light: #FFD666;
  --accent: #FF6B35;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --bg-page: #FFF8ED;
  --bg-card: #FFFFFF;
  --bg-input: #FAFAFA;
  --shadow-sm: 0 4rpx 16rpx rgba(255, 184, 0, 0.12);
  --shadow-md: 0 8rpx 32rpx rgba(255, 184, 0, 0.18);
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
}

.container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

/* 用户信息头部 - 橙黄渐变 */
.user-header {
  display: flex;
  align-items: center;
  padding: 60rpx 36rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #333;
}

.avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.user-info {
  flex: 1;
  margin-left: 32rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
  color: #333;
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
}

.verify-status {
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-top: 12rpx;
  display: inline-block;
  font-weight: 600;
  color: var(--primary-dark);
}

.verify-status.unverify {
  background: rgba(0, 0, 0, 0.15);
  color: #333;
}

.edit-btn {
  font-size: 28rpx;
  padding: 12rpx 28rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  font-weight: 600;
  color: #333;
  background: rgba(255, 255, 255, 0.2);
}

/* 我的发布标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 800;
  padding: 32rpx 36rpx;
  background: var(--bg-card);
  margin-top: 20rpx;
  border-bottom: 2rpx solid var(--bg-input);
  color: var(--text-primary);
}

/* 商品列表 */
.product-list {
  background: var(--bg-card);
}

.product-item {
  display: flex;
  padding: 28rpx 36rpx;
  border-bottom: 2rpx solid var(--bg-input);
  transition: background 0.2s;
}

.product-item:active {
  background: var(--bg-input);
}

.product-item .product-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
}

.product-img-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-img-placeholder::before {
  content: '📷';
  font-size: 48rpx;
  opacity: 0.4;
}

.product-item .product-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-title {
  font-size: 30rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-weight: 600;
  line-height: 1.4;
}

.product-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price {
  font-size: 36rpx;
  color: var(--accent);
  font-weight: 800;
}

.status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.status-1 {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  color: #2E7D32;
}

.status-2 {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  color: #E65100;
}

.status-3 {
  background: var(--bg-input);
  color: var(--text-tertiary);
}

.product-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.action-btn.refresh {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 0, 0.3);
}

.action-btn.delete {
  background: var(--bg-card);
  color: var(--text-tertiary);
  border: 2rpx solid #E0E0E0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  background: var(--bg-card);
}

.empty-state text {
  color: var(--text-tertiary);
  font-size: 28rpx;
  display: block;
  margin-bottom: 8rpx;
}

.go-post-btn {
  margin-top: 32rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #333;
  width: 260rpx;
  border-radius: 36rpx;
  font-weight: 700;
  font-size: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 184, 0, 0.35);
  border: none;
}

/* ========== 功能卡片区域 ========== */
.card {
  background: var(--bg-card);
  margin: 0 24rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* 功能网格 */
.function-card {
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
  padding: 32rpx 0;
}

.function-grid {
  display: flex;
  justify-content: space-around;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.function-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 6rpx 16rpx rgba(255, 184, 0, 0.3);
  margin-bottom: 12rpx;
}

.function-text {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* ========== 更多功能菜单 ========== */
.menu-card {
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 2rpx solid var(--bg-input);
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-input);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

/* ========== 底部安全提示 ========== */
.footer {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
