/* pages/profile/profile.wxss - 全屏横向拉伸布局 **/
page {
  --primary: #FFB800;
  --primary-dark: #FF9500;
  --primary-light: #FFD666;
  --accent: #FF6B35;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --bg-page: #F5F5F5;
  --bg-card: #FFFFFF;
  --bg-input: #FAFAFA;
  --shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --radius-sm: 16rpx;
  --radius-md: 20rpx;
}

/* ========== 1. 撑满全屏容器 ========== */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f9f9f9;
  box-sizing: border-box;
  padding-top: 0;
  justify-content: flex-start;
  overflow: hidden;
}

/* ========== 2. 用户信息头部 - 沉浸式全铺橙色 ========== */
.user-header-card {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding-top: calc(env(safe-area-inset-top) + 125rpx);
  padding-left: 50rpx;
  padding-right: 30rpx;
  padding-bottom: 40rpx;
  margin: 0;
  border-radius: 0;
  flex-shrink: 0;
  width: 100%;
}

.user-header {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 5rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.user-info {
  flex: 1;
  margin-left: 28rpx;
  min-width: 0;
}

.nickname {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.verify-status {
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.25);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 10rpx;
  display: inline-block;
  font-weight: 600;
  color: #fff;
}

.verify-status.unverify {
  background: rgba(0, 0, 0, 0.2);
  color: #fff;
}

.edit-btn {
  font-size: 26rpx;
  padding: 10rpx 25rpx 10rpx 25rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

/* ========== 3. 功能导航卡片 - 全屏横向拉伸 ========== */
.function-card {
  background: var(--bg-card);
  margin: 20rpx 0;
  padding: 0 32rpx;
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
  width: 100%;
}

.icon-nav-container {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  width: 100%;
  padding: 32rpx 0;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  width: 25%;
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 0, 0.25);
}

.function-text {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
}

/* ========== 4. 我的发布卡片 - 全屏横向拉伸 ========== */
.my-release-card {
  background: var(--bg-card);
  margin: 0;
  box-shadow: var(--shadow-sm);
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  width: 100%;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid var(--bg-input);
  flex-shrink: 0;
  color: var(--text-primary);
}

.product-list {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.product-item {
  display: flex;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid var(--bg-input);
}

.product-item:last-child {
  border-bottom: none;
}

.product-item .product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: #f0f0f0;
}

.product-img-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.product-img-placeholder::before {
  content: '📷';
  font-size: 44rpx;
  opacity: 0.4;
}

.product-item .product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-title {
  font-size: 28rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-weight: 600;
  line-height: 1.4;
}

.product-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.price {
  font-size: 34rpx;
  color: var(--accent);
  font-weight: 800;
}

.status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 14rpx;
  font-weight: 600;
}

.status-1 {
  background: #E8F5E9;
  color: #2E7D32;
}

.status-2 {
  background: #FFF3E0;
  color: #E65100;
}

.status-3 {
  background: var(--bg-input);
  color: var(--text-tertiary);
}

.product-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 18rpx;
  font-weight: 600;
}

.action-btn.refresh {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #333;
}

.action-btn.delete {
  background: var(--bg-card);
  color: var(--text-tertiary);
  border: 2rpx solid #E0E0E0;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-content {
  text-align: center;
}

.empty-content text {
  color: var(--text-tertiary);
  font-size: 28rpx;
  display: block;
}

.go-post-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #333;
  width: 220rpx;
  border-radius: 32rpx;
  font-weight: 700;
  font-size: 28rpx;
  border: none;
}

/* ========== 5. 更多服务卡片 - 全屏横向拉伸 ========== */
.menu-card {
  background: var(--bg-card);
  margin: 0;
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
  width: 100%;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid var(--bg-input);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.menu-arrow {
  font-size: 34rpx;
  color: var(--text-tertiary);
}

/* ========== 6. 底部信息 ========== */
.footer {
  text-align: center;
  padding: 20rpx 0 40rpx;
  flex-shrink: 0;
}

.footer-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}